{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Custom footer styles matching the reference */
  .footer .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .footer__block-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .footer__block {
    display: flex;
    flex-direction: column;
  }

  .footer__block--image img {
    max-width: 150px;
    height: auto;
    display: block;
  }

  .v-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gap-4 {
    gap: 1rem;
  }

  .sm\:gap-5 {
    gap: 1.25rem;
  }

  .h6 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    line-height: 1.4;
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
  }

  .text-subdued {
    color: rgba(var(--color-foreground), 0.7);
  }

  .prose {
    line-height: 1.6;
  }

  .prose p {
    margin: 0 0 1rem 0;
  }

  .form-control {
    position: relative;
    margin-bottom: 1rem;
  }

  .input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 0;
    background: transparent;
    font-size: 0.875rem;
    transition: border-color 0.2s;
  }

  .input:focus {
    outline: none;
    border-color: rgba(var(--color-foreground), 0.5);
  }

  .floating-label {
    position: absolute;
    left: 1rem;
    top: 0.75rem;
    pointer-events: none;
    transition: all 0.2s;
    color: rgba(var(--color-foreground), 0.6);
    font-size: 0.75rem;
  }

  .input:focus + .floating-label,
  .input:not(:placeholder-shown) + .floating-label {
    transform: translateY(-1.5rem) scale(0.85);
    background: rgb(var(--color-background));
    padding: 0 0.25rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: none;
    cursor: pointer;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    transition: opacity 0.2s;
  }

  .button:hover {
    opacity: 0.8;
  }

  .align-self-start {
    align-self: flex-start;
  }

  .unstyled-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .gap-2\.5 {
    gap: 0.625rem;
  }

  .link-faded {
    color: rgba(var(--color-foreground), 0.7);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .link-faded:hover {
    color: rgb(var(--color-foreground));
    text-decoration: underline;
  }

  .social-media {
    display: flex;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0 0 0;
  }

  .social-media__item a {
    display: block;
    padding: 0.5rem;
    color: rgba(var(--color-foreground), 0.7);
    transition: color 0.2s;
  }

  .social-media__item a:hover {
    color: rgb(var(--color-foreground));
  }

  .social-media__item svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .footer__aside {
    padding-top: 2rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    text-align: center;
  }

  .text-xxs {
    font-size: 0.625rem;
    letter-spacing: 0.05em;
  }

  .heading {
    font-weight: 600;
  }

  /* Responsive */
  @media screen and (max-width: 989px) {
    .footer__block-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .footer__block-list {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .footer__block--image img {
      margin: 0 auto;
    }
    
    .align-self-start {
      align-self: center;
    }
    
    .footer__block {
      text-align: center;
    }
    
    .form-control {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container">
    <div class="footer__inner">
      <div class="footer__block-list">
        
        <!-- Column 1: Image -->
        <div class="footer__block footer__block--image">
          {% if section.settings.store_image != blank %}
            <img
              src="{{ section.settings.store_image | image_url: width: section.settings.image_width }}"
              srcset="{{ section.settings.store_image | image_url: width: section.settings.image_width }} {{ section.settings.image_width }}w,
                      {{ section.settings.store_image | image_url: width: section.settings.image_width | times: 2 }} {{ section.settings.image_width | times: 2 }}w"
              width="{{ section.settings.store_image.width }}"
              height="{{ section.settings.store_image.height }}"
              sizes="{{ section.settings.image_width }}px"
              alt="{{ section.settings.store_image.alt | default: shop.name | escape }}"
              style="--image-max-width: {{ section.settings.image_width }}px"
              class="constrained-image"
              loading="lazy"
            >
          {% else %}
            {{ 'logo' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <!-- Column 2: Newsletter -->
        <div class="footer__block footer__block--newsletter">
          <div class="v-stack gap-4 sm:gap-5">
            <p class="h6">{{ section.settings.newsletter_heading | default: 'Newsletter' }}</p>
            <div class="prose text-subdued">
              <p>{{ section.settings.newsletter_subtext | default: 'Sign up to our newsletter to receive exclusive offers.' }}</p>
            </div>
            {%- form 'customer', id: 'newsletter-form-' | append: section.id, class: 'form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="form-control">
                <input
                  id="input--{{ section.id }}--contactemail"
                  class="input"
                  type="email"
                  dir="ltr"
                  name="contact[email]"
                  placeholder=" "
                  autocomplete="email"
                  enterkeyhint="send"
                  required
                >
                <label for="input--{{ section.id }}--contactemail" class="floating-label text-xs">
                  {{ section.settings.email_placeholder | default: 'E-mail' }}
                </label>
              </div>
              <div class="align-self-start">
                <button type="submit" class="button">{{ section.settings.subscribe_button_label | default: 'Subscribe' }}</button>
              </div>
              {%- if form.posted_successfully? -%}
                <p class="form-success" style="color: green; margin-top: 1rem;">{{ 'newsletter.success' | t }}</p>
              {%- endif -%}
              {%- if form.errors -%}
                <p class="form-error" style="color: red; margin-top: 1rem;">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
              {%- endif -%}
            {%- endform -%}
          </div>
        </div>

        <!-- Column 3: Footer Links -->
        <div class="footer__block footer__block--links">
          <div class="v-stack gap-4 sm:gap-5">
            <p class="h6">{{ section.settings.footer_links_heading | default: 'Footer' }}</p>
            <ul class="v-stack gap-2.5 unstyled-list" role="list">
              {% for link in section.settings.footer_menu.links %}
                <li>
                  <a href="{{ link.url }}" class="link-faded">{{ link.title | escape }}</a>
                </li>
              {% else %}
                <!-- Default links if no menu is selected -->
                <li><a href="/pages/about-us" class="link-faded">About</a></li>
                <li><a href="/pages/social" class="link-faded">Social</a></li>
                <li><a href="/pages/trade" class="link-faded">Trade</a></li>
                <li><a href="/pages/security-privacy" class="link-faded">Security & Privacy</a></li>
                <li><a href="/pages/finance" class="link-faded">0% Finance</a></li>
              {% endfor %}
            </ul>
          </div>
        </div>

        <!-- Column 4: About Text -->
        <div class="footer__block footer__block--text">
          <div class="v-stack gap-4 sm:gap-5">
            <p class="h6">{{ section.settings.about_heading | default: 'About' }}</p>
            <div class="prose text-subdued">
              <p>{{ section.settings.about_description | default: 'Use this text area to tell your customers about your brand and vision. You can change it in the theme editor.' }}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Social Icons -->
      {% if section.settings.show_social_icons %}
        <ul class="social-media social-media--list unstyled-list" role="list">
          {% if settings.social_instagram_link != blank %}
            <li class="social-media__item branding-colors--instagram">
              <a href="{{ settings.social_instagram_link }}" class="tap-area" target="_blank" rel="noopener" aria-label="Follow on Instagram">
                <svg aria-hidden="true" focusable="false" width="24" class="icon icon-instagram" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2.4c-2.607 0-2.934.011-3.958.058-1.022.046-1.72.209-2.33.446a4.705 4.705 0 0 0-1.7 1.107 4.706 4.706 0 0 0-1.108 1.7c-.237.611-.4 1.31-.446 2.331C2.41 9.066 2.4 9.392 2.4 12c0 2.607.011 2.934.058 3.958.046 1.022.209 1.72.446 2.33a4.706 4.706 0 0 0 1.107 1.7c.534.535 1.07.863 1.7 1.108.611.237 1.309.4 2.33.446 1.025.047 1.352.058 3.959.058s2.934-.011 3.958-.058c1.022-.046 1.72-.209 2.33-.446a4.706 4.706 0 0 0 1.7-1.107 4.706 4.706 0 0 0 1.108-1.7c.237-.611.4-1.31.446-2.33.047-1.025.058-1.352.058-3.959s-.011-2.934-.058-3.958c-.047-1.022-.209-1.72-.446-2.33a4.706 4.706 0 0 0-1.107-1.7 4.705 4.705 0 0 0-1.7-1.108c-.611-.237-1.31-.4-2.331-.446C14.934 2.41 14.608 2.4 12 2.4Zm0 1.73c2.563 0 2.867.01 3.88.056.935.042 1.443.199 1.782.33.448.174.768.382 1.104.718.336.336.544.656.718 1.104.131.338.287.847.33 1.783.046 1.012.056 1.316.056 3.879 0 2.563-.01 2.867-.056 3.88-.043.935-.199 1.444-.33 1.782a2.974 2.974 0 0 1-.719 1.104 2.974 2.974 0 0 1-1.103.718c-.339.131-.847.288-1.783.33-1.012.046-1.316.056-3.88.056-2.563 0-2.866-.01-3.878-.056-.936-.042-1.445-.199-1.783-.33a2.974 2.974 0 0 1-1.104-.718 2.974 2.974 0 0 1-.718-1.104c-.131-.338-.288-.847-.33-1.783-.047-1.012-.056-1.316-.056-3.879 0-2.563.01-2.867.056-3.88.042-.935.199-1.443.33-1.782.174-.448.382-.768.718-1.104a2.974 2.974 0 0 1 1.104-.718c.338-.131.847-.288 1.783-.33C9.133 4.14 9.437 4.13 12 4.13Zm0 11.07a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4Zm0-8.13a4.93 4.93 0 1 0 0 9.86 4.93 4.93 0 0 0 0-9.86Zm6.276-.194a1.152 1.152 0 1 1-2.304 0 1.152 1.152 0 0 1 2.304 0Z" fill="currentColor"></path>
                </svg>
              </a>
            </li>
          {% endif %}
          {% if settings.social_facebook_link != blank %}
            <li class="social-media__item">
              <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Follow on Facebook">
                <svg aria-hidden="true" focusable="false" width="24" class="icon icon-facebook" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M10.183 21.85v-8.868H7.2v-3.23h2.983V6.982c0-2.945 1.8-4.55 4.426-4.55 1.256 0 2.336.094 2.65.136v3.072h-1.818c-1.428 0-1.705.68-1.705 1.675v2.195h3.41l-.445 3.23h-2.965v8.868h-3.553Z" fill="currentColor"/>
                </svg>
              </a>
            </li>
          {% endif %}
          {% if settings.social_twitter_link != blank %}
            <li class="social-media__item">
              <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="Follow on Twitter">
                <svg aria-hidden="true" focusable="false" width="24" class="icon icon-twitter" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
                </svg>
              </a>
            </li>
          {% endif %}
        </ul>
      {% endif %}

      <!-- Footer Aside -->
      <div class="footer__aside">
        <p class="heading text-subdued text-xxs">
          &copy; {{ 'now' | date: '%Y' }} - {{ shop.name }}
          {% if section.settings.show_powered_by %}
            <a target="_blank" rel="nofollow" href="https://www.shopify.com?utm_campaign=poweredby&amp;utm_medium=shopify&amp;utm_source=onlinestore">Powered by Shopify</a>
          {% endif %}
        </p>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Column 1 - Image"
    },
    {
      "type": "image_picker",
      "id": "store_image",
      "label": "Store Logo/Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Image Width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Column 2 - Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_subtext",
      "label": "Newsletter Subtext",
      "default": "Sign up to our newsletter to receive exclusive offers."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "subscribe_button_label",
      "label": "Subscribe Button Label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Column 3 - Footer Links"
    },
    {
      "type": "text",
      "id": "footer_links_heading",
      "label": "Footer Links Heading",
      "default": "Footer"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "info": "Select a menu for footer links. If none selected, default links will show."
    },
    {
      "type": "header",
      "content": "Column 4 - About"
    },
    {
      "type": "text",
      "id": "about_heading",
      "label": "About Heading",
      "default": "About"
    },
    {
      "type": "textarea",
      "id": "about_description",
      "label": "About Description",
      "default": "Use this text area to tell your customers about your brand and vision. You can change it in the theme editor."
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Footer Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show 'Powered by Shopify'",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [],
  "default": {
    "settings": {}
  }
}
{% endschema %}